% diagram macros — no arrows, no value labels, just red dots
\newcommand{\Thermometer}[2]{\begin{tikzpicture}[scale=0.25,baseline=0]\node[above,font=\bfseries\tiny]at(0,5){#1};
\draw[thick](0.1,-0.1)--(0.1,4.5);\foreach\y/\l in{0/-10,1/0,2/10,3/20,4/30,5/40}{\draw[thick](0,\y)--(0.4,\y);\node[left,font=\tiny]at(-0.02,\y){\l};}
\draw[very thick,rounded corners=1](0.45,0)rectangle(0.85,4.5);\draw[very thick,rounded corners=2](0.35,-0.15)rectangle(0.95,0.15);
\fill[red!80!black](0.45,0)rectangle(0.85,#2/10+1);\fill[red!80!black](0.36,-0.14)rectangle(0.94,0.14);
\fill[red] (0.65,#2/10+1) circle (0.08);
\end{tikzpicture}}
\newcommand{\Ruler}[2]{\begin{tikzpicture}[scale=0.25,baseline=0]\node[above,font=\bfseries\tiny]at(7.5,0.7){#1};
\draw[very thick](0,0)--(15,0);\foreach\x in{0,...,15}{\draw[thick](\x,0)--(\x,-0.1);\node[below,font=\tiny]at(\x,-0.12){\x};}
\foreach\x in{0.1,0.2,...,14.9}{\draw[thin](\x,0)--(\x,-0.03);}
\fill[red] (#2,0) circle (0.08);
\end{tikzpicture}}
\newcommand{\MeasuringJug}[2]{\begin{tikzpicture}[scale=0.25,baseline=0]\node[above,font=\bfseries\tiny]at(2,5){#1};
\draw[very thick](0.3,0)--(0.3,4.5)--(0.8,4.5)--(1.3,4.5)--(1.8,4.5)--(1.8,0)--cycle;
\foreach\y/\l in{0/0,0.9/200,1.8/400,2.7/600,3.6/800,4.5/1000}{\draw[thick](1.8,\y)--(2.1,\y);\node[right,font=\tiny]at(2.2,\y){\l};}
\fill[blue!40!white,opacity=0.6](0.31,0)rectangle(1.79,#2/222.2);\draw[blue,thick](0.31,#2/222.2)--(1.79,#2/222.2);
\fill[blue] (2.0,#2/222.2) circle (0.08);
\end{tikzpicture}}
